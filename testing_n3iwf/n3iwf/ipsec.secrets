# strongSwan IPsec Secrets — Pre-Shared Key
# ===========================================
# File ini diletakkan di: /etc/ipsec.secrets pada Raspberry Pi 5
# Izin file HARUS 600: sudo chmod 600 /etc/ipsec.secrets
#
# Format: <left_id> <right_id> : PSK "<secret>"
# GANTI "AquacultureThesis2025" dengan PSK yang sama
# seperti yang dikonfigurasi di Amarisoft N3IWF Callbox.

aquaculture-rpi5@thesis.local n3iwf@amarisoft.local : PSK "AquacultureThesis2025"
